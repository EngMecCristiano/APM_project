# APM Analytics — Variáveis de Ambiente
# Copie para .env e ajuste conforme seu ambiente

# ── Backend ───────────────────────────────────────────
BACKEND_URL=http://localhost:8002
TZ=America/Sao_Paulo
PYTHONPATH=/app

# CORS — origens permitidas (separadas por vírgula)
# Em produção, coloque a URL exata do frontend:
# ALLOWED_ORIGINS=https://apm-app-production.up.railway.app
# Em desenvolvimento, deixe vazio (libera localhost automaticamente)
ALLOWED_ORIGINS=

# ── Agente de Manutenção Prescritiva (IA) ─────────────
# Sem esta chave, o sistema usa Expert System (fallback automático, sem custo)
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Desenvolvimento local (sem Docker) ────────────────
# uvicorn backend.main:app --port 8002 --reload
# streamlit run frontend/app.py
